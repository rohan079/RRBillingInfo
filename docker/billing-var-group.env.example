# Azure DevOps: BillingVarGroup | Render: Service → Environment (same variable names)
# Copy to billing-var-group.env (gitignored) for local docker compose.
#
# --- Render (Spring Boot web service) ---
# Easiest: link Postgres in Render → DATABASE_URL is set automatically.
# Or set JDBC explicitly:
# SPRING_DATASOURCE_URL=jdbc:postgresql://dpg-xxxx-a.oregon-postgres.render.com:5432/rrbillingdb?sslmode=require
# SPRING_DATASOURCE_USERNAME=rrbillingdb_user
# SPRING_DATASOURCE_PASSWORD=your-password
# APP_CORS_ALLOWED_ORIGINS=https://your-angular-site.onrender.com
# PORT is injected by Render (do not set manually).

# Optional split fields (documentation / other tools)
# POSTGRES_HOST=dpg-xxxx-a.oregon-postgres.render.com
# POSTGRES_PORT=5432
# POSTGRES_DB=rrbillingdb
# POSTGRES_USER=rrbillingdb_user

# Local docker-compose stack (internal postgres service)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/postgres?connectTimeout=10&sslmode=prefer
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=admin
POSTGRES_PASSWORD=admin
